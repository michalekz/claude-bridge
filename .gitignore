# Node.js dependencies — installed locally per developer
node_modules/

# Build artifact policy: keep dist/*.cjs (installable artifacts —
# bundle.cjs = MCP server, statusline.cjs = statusLine wrapper (v0.9.0+),
# and future refresh-limits.cjs / setup-check.cjs). Ignore all other build
# output plus TypeScript incremental files.
dist/*
!dist/*.cjs
*.tsbuildinfo

# Test coverage
coverage/
.coverage/

# Environment files (never commit secrets)
.env
.env.local
.env.*.local

# IDE / editor
.idea/
.vscode/
*.swp
*.swo

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
npm-debug.log*

# Temporary / scratch
.tmp/
tmp/
*.tmp

# Runtime data (when developing locally against ~/.claude-bridge/)
.claude-bridge-test/
reference/

# Per-clone scratch space — anything here is ignored by git.
# Use for: internal prep notes, drafts, secrets staging, scratch scripts
local/
