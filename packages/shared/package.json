{
  "name": "@claude-bridge/shared",
  "version": "0.10.0-alpha.0",
  "private": true,
  "description": "Shared utilities for claude-bridge packages: paths, atomic writes, structured logging, control-plane path helpers.",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./atomic-write": "./src/atomic-write.ts",
    "./logger": "./src/logger.ts",
    "./paths": "./src/paths.ts",
    "./control-paths": "./src/control-paths.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run tests/",
    "check": "biome check src tests"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18"
  }
}
