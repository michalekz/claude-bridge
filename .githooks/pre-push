#!/usr/bin/env bash
# Pre-push hook — runs the same checks as CI before pushing.
#
# Mirrors .github/workflows/ci.yml (minus `npm ci` and `npm run build` which
# are expensive and don't gate behavior beyond what these checks already verify).
#
# To enable in your local clone, run once:
#
#   git config core.hooksPath .githooks
#
# To bypass for a single push (e.g., WIP branch):
#
#   git push --no-verify
#
# Hook is idempotent and exits non-zero on any failure.

set -euo pipefail

# Workspace packages to check. Added incrementally as the repo grows; missing
# dirs are skipped silently so branches predating the layout still push.
PACKAGES=(
  "servers/claude-bridge"
  "servers/claude-bridge-daemon"
  "packages/shared"
)

REPO_ROOT="$(git rev-parse --show-toplevel)"

run_checks() {
  local pkg_dir="$1"
  local full="$REPO_ROOT/$pkg_dir"
  if [ ! -d "$full" ]; then
    return 0
  fi
  echo
  echo "▸ pre-push: [$pkg_dir] biome + tsc + tests"
  cd "$full"

  if ! npm run check --silent --if-present; then
    echo
    echo "✗ biome check failed in $pkg_dir. Fix with:"
    echo "    cd $pkg_dir && npx biome check --write src tests"
    echo
    echo "Or bypass with: git push --no-verify"
    exit 1
  fi

  if ! npm run typecheck --silent --if-present; then
    echo
    echo "✗ tsc typecheck failed in $pkg_dir. See errors above."
    echo "Or bypass with: git push --no-verify"
    exit 1
  fi

  if ! npm test --silent --if-present; then
    echo
    echo "✗ tests failed in $pkg_dir. See output above."
    echo "Or bypass with: git push --no-verify"
    exit 1
  fi
}

for pkg in "${PACKAGES[@]}"; do
  run_checks "$pkg"
done

echo
echo "✓ pre-push: all workspace checks passed"
